{
  "description": "AgenticDevOps 파이프라인 자동화 훅",
  "hooks": {
    "SubagentStop": [
      {
        "matcher": "agentic-devops:",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/scripts/subagent-stop-handler.js",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
